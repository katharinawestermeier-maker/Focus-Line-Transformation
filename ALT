<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Focus Line Transformation – acterience</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red:      #C0392B;
    --red-dark: #9B2318;
    --red-glow: rgba(192,57,43,0.12);
    --dark:     #111111;
    --mid:      #555555;
    --light:    #F7F7F7;
    --border:   #E4E4E4;
    --white:    #FFFFFF;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    color: var(--dark);
    background: var(--white);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── SCROLL ANIMATIONS ── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .65s cubic-bezier(.4,0,.2,1), transform .65s cubic-bezier(.4,0,.2,1);
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
  .reveal-delay-1 { transition-delay: .1s; }
  .reveal-delay-2 { transition-delay: .2s; }
  .reveal-delay-3 { transition-delay: .3s; }
  .reveal-delay-4 { transition-delay: .4s; }
  .reveal-delay-5 { transition-delay: .5s; }

  /* ── NAV ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 56px;
    height: 64px;
    box-shadow: 0 1px 0 var(--border);
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--dark);
  }
  .nav-brand-dot {
    width: 8px; height: 8px;
    background: var(--red);
    border-radius: 50%;
  }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-size: 12px;
    font-weight: 500;
    color: var(--mid);
    text-decoration: none;
    letter-spacing: .05em;
    text-transform: uppercase;
    transition: color .2s;
    position: relative;
    padding-bottom: 2px;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 1px;
    background: var(--red);
    transform: scaleX(0);
    transition: transform .2s;
  }
  .nav-links a:hover { color: var(--dark); }
  .nav-links a:hover::after { transform: scaleX(1); }

  /* ── HERO ── */
  .hero {
    background: var(--dark);
    color: var(--white);
    padding: 120px 56px 100px;
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .hero-bg-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(192,57,43,.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(192,57,43,.06) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .hero-accent {
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    background: var(--red);
  }
  .hero-content { position: relative; z-index: 1; max-width: 760px; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 28px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--red);
  }
  .hero h1 {
    
    font-size: clamp(44px, 6vw, 76px);
    font-weight: 700;
    line-height: 1.08;
    margin-bottom: 28px;
    letter-spacing: -.01em;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--red);
  }
  .hero-sub {
    font-size: 17px;
    font-weight: 300;
    color: #AAAAAA;
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: 44px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--red);
    color: var(--white);
    padding: 14px 30px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: .06em;
    text-transform: uppercase;
    transition: background .2s, gap .2s;
  }
  .hero-cta:hover { background: var(--red-dark); gap: 14px; }
  .hero-cta svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }

  /* ── SECTION WRAPPER ── */
  section { padding: 88px 56px; }
  section.bg-light { background: var(--light); }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 16px;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 20px; height: 1px;
    background: var(--red);
  }
  .section-title {
    
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    letter-spacing: -.01em;
  }
  .section-intro {
    font-size: 16px;
    color: var(--mid);
    max-width: 580px;
    margin-bottom: 56px;
    line-height: 1.7;
  }

  /* ── QUOTE ── */
  .mission-quote {
    position: relative;
    padding: 36px 40px;
    background: var(--dark);
    color: var(--white);
    max-width: 760px;
    margin-bottom: 64px;
  }
  .mission-quote::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--red);
  }
  .mission-quote p {
    font-size: 18px;
    font-weight: 300;
    font-style: italic;
    line-height: 1.7;
    color: #DDDDDD;
  }

  /* ── MEHRWERT CARDS ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2px;
  }
  .card {
    background: var(--white);
    padding: 36px 28px;
    border-top: 2px solid transparent;
    transition: border-color .25s, box-shadow .25s;
  }
  .bg-light .card { background: var(--white); }
  .card:hover {
    border-top-color: var(--red);
    box-shadow: 0 8px 32px rgba(0,0,0,.07);
  }
  .card-num {
    font-size: 11px;
    font-weight: 700;
    color: var(--red);
    letter-spacing: .12em;
    margin-bottom: 20px;
    opacity: .7;
  }
  .card h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .card p { font-size: 14px; color: var(--mid); line-height: 1.65; }

  /* ── ZIELE / AUFGABEN / BESONDERHEITEN ── */
  .zab-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  @media (max-width: 900px) { .zab-grid { grid-template-columns: 1fr; } }
  .zab-col {
    padding: 40px 32px;
    background: var(--white);
  }
  .zab-col:first-child { background: var(--dark); color: var(--white); }
  .zab-col:first-child .zab-heading { color: var(--red); }
  .zab-col:first-child .zab-item { border-color: rgba(255,255,255,.1); }
  .zab-col:first-child .zab-item p { color: #BBBBBB; }
  .zab-heading {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .zab-heading::before { content: ''; display: block; width: 16px; height: 1px; background: currentColor; }
  .zab-item {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .zab-item:last-child { border-bottom: none; }
  .zab-dash {
    color: var(--red);
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    min-width: 12px;
  }
  .zab-item p { font-size: 14px; color: var(--mid); line-height: 1.55; }

  /* ── SERVICE PORTFOLIO ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2px;
  }
  .service-item {
    background: var(--white);
    padding: 32px 28px;
    position: relative;
    transition: box-shadow .2s;
  }
  .service-item:hover { box-shadow: 0 6px 28px rgba(0,0,0,.07); }
  .service-num {
    font-size: 36px;
    
    font-weight: 700;
    color: var(--red);
    opacity: .15;
    line-height: 1;
    margin-bottom: 16px;
  }
  .service-item h3 { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
  .service-item p { font-size: 13px; color: var(--mid); line-height: 1.6; }

  /* ── METHODEN ── */
  .methoden-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
    max-width: 900px;
  }
  .methoden-item {
    background: var(--white);
    padding: 28px 24px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
    transition: box-shadow .2s;
  }
  .methoden-item:hover { box-shadow: 0 4px 20px rgba(0,0,0,.06); }
  .methoden-icon {
    width: 40px; height: 40px; min-width: 40px;
    background: var(--red-glow);
    border: 1px solid rgba(192,57,43,.2);
    display: flex; align-items: center; justify-content: center;
  }
  .methoden-icon svg { width: 18px; height: 18px; stroke: var(--red); fill: none; stroke-width: 1.5; }
  .methoden-item p { font-size: 14px; color: var(--dark); font-weight: 500; line-height: 1.5; margin-top: 10px; }

  /* ── TEAM ── */
  .team-owner-card {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 56px;
    padding: 32px;
    background: var(--dark);
    color: var(--white);
    max-width: 400px;
    position: relative;
  }
  .team-owner-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--red);
  }
  .avatar {
    width: 80px; height: 80px; min-width: 80px;
    border-radius: 50%;
    background: var(--red);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    overflow: hidden;
    border: 2px solid rgba(255,255,255,.1);
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .avatar-sm { width: 68px; height: 68px; min-width: 68px; font-size: 17px; }
  .owner-info h3 { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .owner-info .role { font-size: 12px; color: #999; letter-spacing: .04em; }
  .owner-info .badge {
    display: inline-block;
    margin-top: 10px;
    background: var(--red);
    color: var(--white);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 3px 10px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 2px;
  }
  .team-card {
    background: var(--white);
    padding: 28px 16px;
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
    transition: transform .2s, box-shadow .2s;
    cursor: default;
  }
  .team-card:hover { transform: translateY(-3px); box-shadow: 0 10px 32px rgba(0,0,0,.08); }
  .team-card h4 { font-size: 14px; font-weight: 600; line-height: 1.3; }
  .team-card .role { font-size: 11px; color: var(--mid); letter-spacing: .04em; }

  /* ── PROFIL ── */
  .profil-list { display: flex; flex-direction: column; max-width: 760px; }
  .profil-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }
  .profil-item:last-child { border-bottom: none; }
  .profil-num {
    font-size: 11px;
    font-weight: 700;
    color: var(--red);
    padding-top: 3px;
    letter-spacing: .04em;
  }
  .profil-item h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
  .profil-item p { font-size: 14px; color: var(--mid); line-height: 1.6; }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    color: #555;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 56px;
    font-size: 12px;
    letter-spacing: .04em;
  }
  footer .footer-brand { color: var(--white); font-weight: 600; }
  footer .footer-line { color: var(--red); }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    section { padding: 56px 20px; }
    .hero { padding: 80px 20px 64px; min-height: auto; }
    footer { padding: 24px 20px; flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
</head>
